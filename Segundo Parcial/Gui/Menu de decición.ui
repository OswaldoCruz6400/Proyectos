  <property name="styleSheet">
   <string notr="true">/* Ventana principal */
QMainWindow {
    background-color: #f4f6f8;
}

/* Barra de menú */
QMenuBar {
    background-color: #2c3e50;
    color: white;
    padding: 6px;
    font-size: 14px;
    font-family: &quot;Segoe UI&quot;, Arial;
}

/* Items del menú */
QMenuBar::item {
    background: transparent;
    padding: 6px 12px;
    border-radius: 4px;
}

/* Hover en menú */
QMenuBar::item:selected {
    background-color: #34495e;
}

/* Menú desplegable */
QMenu {
    background-color: #ffffff;
    border: 1px solid #ccc;
    padding: 5px;
}

/* Items dentro del menú */
QMenu::item {
    padding: 8px 20px;
    color: #333;
}

/* Hover en items */
QMenu::item:selected {
    background-color: #4f73b8;
    color: white;
    border-radius: 4px;
}

/* Separadores */
QMenu::separator {
    height: 1px;
    background: #ddd;
    margin: 5px 0;
}

/* Barra de estado */
QStatusBar {
    background-color: #ecf0f1;
    color: #333;
    border-top: 1px solid #ccc;
}</string>
