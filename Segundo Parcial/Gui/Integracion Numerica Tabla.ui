    color: white;
    font-size: 20px;
    border-radius: 12px;
    padding: 10px 20px;
    min-width: 150px;
    min-height: 40px;
}

/* Hover del botón */
QPushButton:hover {
    background-color: #3f63a5;
}

/* Botón presionado */
